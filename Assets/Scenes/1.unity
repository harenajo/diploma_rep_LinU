  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u0412\u0456\u0442\u0430\u044E, \u043C\u0438 \u0437 \u0432\u0430\u043C\u0438
    \u0449\u0435 \u043D\u0435 \u0437\u043D\u0430\u0439\u043E\u043C\u0456. \u0410\u043B\u0435
    \u0443 \u043C\u0435\u043D\u0435 \u0454 \u0434\u043E \u0432\u0430\u0441 \u043E\u0434\u043D\u0430
    \u0441\u043F\u0440\u0430\u0432\u0430.\n\n\u0414\u0435\u044F\u043A\u0430 \u0437\u0430\u0433\u0430\u0434\u043A\u0430.
    \u0412\u0438 \u0434\u0443\u0436\u0435 \u0440\u043E\u0437\u0443\u043C\u043D\u0430
    \u043B\u044E\u0434\u0438\u043D\u0430, \u044F\u043A\u0449\u043E \u0437\u043C\u043E\u0436\u0435\u0442\u0435
    \u0437\u0440\u043E\u0437\u0443\u043C\u0456\u0442\u0438 \u0449\u043E \u0442\u0443\u0442
    \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u043E.\n\nYmnx nx f yjxy.\n\n\u0427\u0435\u043A\u0430\u044E
    \u043D\u0430 \u0432\u0430\u0448\u0443 \u0432\u0456\u0434\u043F\u043E\u0432\u0456\u0434\u044C)\n\n\u0423
    \u0432\u0430\u0441 \u0454 \u0446\u0456\u043B\u0438\u0445 \u0434\u0432\u0456 \u0433\u043E\u0434\u0438\u043D\u0438
    \u043F'\u044F\u0442\u043D\u0430\u0434\u0446\u044F\u0442\u044C \u0445\u0432\u0438\u043B\u0438\u043D!\n\nP.S
    \u041D\u0430 \u0432\u0430\u0448\u043E\u043C\u0443 \u043C\u0456\u0441\u0446\u0456
    \u044F \u0431 \u043D\u0435 \u0456\u0433\u043D\u043E\u0440\u0443\u0432\u0430\u0432
    \u0446\u0435 \u043F\u043E\u0432\u0456\u0434\u043E\u043C\u043B\u0435\u043D\u043D\u044F.
    \u0426\u0435 \u043D\u0435 \u0432\u0438\u0445\u043E\u0432\u0430\u043D\u0456\u0441\u0442\u044C,
    \u043F\u043B\u044E\u0441 \u043C\u043E\u0436\u0435 \u043C\u0430\u0442\u0438 \u0434\u0435\u044F\u043A\u0456
    \u043D\u0430\u0441\u043B\u0456\u0434\u043A\u0438... \u0410\u043B\u0435 \u043D\u0435
    \u0431\u0443\u0434\u0443 \u0432\u0430\u0441 \u043B\u044F\u043A\u0430\u0442\u0438.
    \u041F\u043E\u043A\u0438 \u0449\u043E)))"
