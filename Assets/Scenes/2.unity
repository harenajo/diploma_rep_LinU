  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u0427\u0430\u0441\u0442\u043E\u0442\u043D\u0438\u0439 \u0430\u043D\u0430\u043B\u0456\u0437
    \u0454 \u043E\u0434\u043D\u0438\u043C \u0456\u0437 \u043D\u0430\u0439\u0441\u0442\u0430\u0440\u0456\u0448\u0438\u0445
    \u043C\u0435\u0442\u043E\u0434\u0456\u0432 \u043A\u0440\u0438\u043F\u0442\u043E\u0430\u043D\u0430\u043B\u0456\u0437\u0443
    \u2014 \u043D\u0430\u0443\u043A\u0438 \u043F\u0440\u043E \u0437\u043B\u0430\u043C
    \u0448\u0438\u0444\u0440\u0456\u0432. \u0419\u043E\u0433\u043E \u043F\u043E\u044F\u0432\u0430
    \u043F\u043E\u0432'\u044F\u0437\u0430\u043D\u0430 \u0437 \u0440\u043E\u0431\u043E\u0442\u0430\u043C\u0438
    \u0430\u0440\u0430\u0431\u0441\u044C\u043A\u043E\u0433\u043E \u0432\u0447\u0435\u043D\u043E\u0433\u043E
    \u0410\u043B\u044C-\u041A\u0456\u043D\u0434\u0456, \u044F\u043A\u0438\u0439 \u0443
    IX \u0441\u0442\u043E\u043B\u0456\u0442\u0442\u0456 \u0432\u043F\u0435\u0440\u0448\u0435
    \u043E\u043F\u0438\u0441\u0430\u0432 \u043C\u043E\u0436\u043B\u0438\u0432\u0456\u0441\u0442\u044C
    \u0432\u0438\u043A\u043E\u0440\u0438\u0441\u0442\u0430\u043D\u043D\u044F \u0441\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u043A\u0438
    \u043B\u0456\u0442\u0435\u0440 \u0434\u043B\u044F \u0440\u043E\u0437\u043A\u0440\u0438\u0442\u0442\u044F
    \u0437\u0430\u0448\u0438\u0444\u0440\u043E\u0432\u0430\u043D\u0438\u0445 \u043F\u043E\u0432\u0456\u0434\u043E\u043C\u043B\u0435\u043D\u044C.\n\n\u041C\u0435\u0442\u043E\u0434
    \u0491\u0440\u0443\u043D\u0442\u0443\u0454\u0442\u044C\u0441\u044F \u043D\u0430
    \u0442\u043E\u043C\u0443, \u0449\u043E \u0440\u0456\u0437\u043D\u0456 \u043B\u0456\u0442\u0435\u0440\u0438
    \u0432 \u0431\u0443\u0434\u044C-\u044F\u043A\u0456\u0439 \u043C\u043E\u0432\u0456
    \u0437\u0443\u0441\u0442\u0440\u0456\u0447\u0430\u044E\u0442\u044C\u0441\u044F
    \u0437 \u0440\u0456\u0437\u043D\u043E\u044E \u0447\u0430\u0441\u0442\u043E\u0442\u043E\u044E.
    \n\n\u041D\u0430\u043F\u0440\u0438\u043A\u043B\u0430\u0434, \u0432 \u0443\u043A\u0440\u0430\u0457\u043D\u0441\u044C\u043A\u0456\u0439
    \u043C\u043E\u0432\u0456 \u043D\u0430\u0439\u0447\u0430\u0441\u0442\u0456\u0448\u0435
    \u0432\u0438\u043A\u043E\u0440\u0438\u0441\u0442\u043E\u0432\u0443\u044E\u0442\u044C\u0441\u044F
    \u043B\u0456\u0442\u0435\u0440\u0438 \u041E, \u0410, \u0406, \u041D, \u0422 \u0442\u0430
    \u0415. \u042F\u043A\u0449\u043E \u0432 \u0437\u0430\u0448\u0438\u0444\u0440\u043E\u0432\u0430\u043D\u043E\u043C\u0443
    \u0442\u0435\u043A\u0441\u0442\u0456 \u043F\u0435\u0432\u043D\u0438\u0439 \u0441\u0438\u043C\u0432\u043E\u043B
    \u0437\u0443\u0441\u0442\u0440\u0456\u0447\u0430\u0454\u0442\u044C\u0441\u044F
    \u043E\u0441\u043E\u0431\u043B\u0438\u0432\u043E \u0447\u0430\u0441\u0442\u043E,
    \u0456\u0441\u043D\u0443\u0454 \u0439\u043C\u043E\u0432\u0456\u0440\u043D\u0456\u0441\u0442\u044C,
    \u0449\u043E \u0432\u0456\u043D \u0432\u0456\u0434\u043F\u043E\u0432\u0456\u0434\u0430\u0454
    \u043E\u0434\u043D\u0456\u0439 \u0456\u0437 \u043D\u0430\u0439\u0443\u0436\u0438\u0432\u0430\u043D\u0456\u0448\u0438\u0445
    \u043B\u0456\u0442\u0435\u0440 \u043C\u043E\u0432\u0438.\n\n\u0414\u043B\u044F
    \u043F\u0440\u043E\u0432\u0435\u0434\u0435\u043D\u043D\u044F \u0430\u043D\u0430\u043B\u0456\u0437\u0443
    \u043F\u0456\u0434\u0440\u0430\u0445\u043E\u0432\u0443\u0454\u0442\u044C\u0441\u044F
    \u043A\u0456\u043B\u044C\u043A\u0456\u0441\u0442\u044C \u043F\u043E\u044F\u0432
    \u043A\u043E\u0436\u043D\u043E\u0433\u043E \u0441\u0438\u043C\u0432\u043E\u043B\u0443
    \u0432 \u043F\u043E\u0432\u0456\u0434\u043E\u043C\u043B\u0435\u043D\u043D\u0456.
    \u041E\u0442\u0440\u0438\u043C\u0430\u043D\u0456 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u0438
    \u043F\u043E\u0440\u0456\u0432\u043D\u044E\u044E\u0442\u044C\u0441\u044F \u0437\u0456
    \u0441\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u0447\u043D\u0438\u043C\u0438
    \u0434\u0430\u043D\u0438\u043C\u0438 \u043C\u043E\u0432\u0438, \u043F\u0456\u0441\u043B\u044F
    \u0447\u043E\u0433\u043E \u0432\u0438\u0441\u0443\u0432\u0430\u044E\u0442\u044C\u0441\u044F
    \u043F\u0440\u0438\u043F\u0443\u0449\u0435\u043D\u043D\u044F \u0449\u043E\u0434\u043E
    \u043C\u043E\u0436\u043B\u0438\u0432\u0438\u0445 \u0437\u0430\u043C\u0456\u043D.
    \n\n"
