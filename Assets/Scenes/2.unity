  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u0417\u0430\u0432\u0434\u044F\u043A\u0438 \u0446\u044C\u043E\u043C\u0443
    \u043E\u0434\u043D\u0430\u043A\u043E\u0432\u0456 \u043B\u0456\u0442\u0435\u0440\u0438
    \u0432\u0456\u0434\u043A\u0440\u0438\u0442\u043E\u0433\u043E \u0442\u0435\u043A\u0441\u0442\u0443
    \u043C\u043E\u0436\u0443\u0442\u044C \u043F\u0435\u0440\u0435\u0442\u0432\u043E\u0440\u044E\u0432\u0430\u0442\u0438\u0441\u044F
    \u043D\u0430 \u0440\u0456\u0437\u043D\u0456 \u0441\u0438\u043C\u0432\u043E\u043B\u0438
    \u0448\u0438\u0444\u0440\u043E\u0442\u0435\u043A\u0441\u0442\u0443. \u0421\u0430\u043C\u0435
    \u0446\u044F \u043E\u0441\u043E\u0431\u043B\u0438\u0432\u0456\u0441\u0442\u044C
    \u0440\u043E\u0431\u0438\u0442\u044C \u0448\u0438\u0444\u0440 \u0412\u0456\u0436\u0435\u043D\u0435\u0440\u0430
    \u0437\u043D\u0430\u0447\u043D\u043E \u0441\u0442\u0456\u0439\u043A\u0456\u0448\u0438\u043C
    \u0437\u0430 \u0448\u0438\u0444\u0440 \u0426\u0435\u0437\u0430\u0440\u044F. \u0414\u043B\u044F
    \u0443\u0441\u043F\u0456\u0448\u043D\u043E\u0433\u043E \u0440\u043E\u0437\u0448\u0438\u0444\u0440\u0443\u0432\u0430\u043D\u043D\u044F
    \u043D\u0435\u043E\u0431\u0445\u0456\u0434\u043D\u043E \u0437\u043D\u0430\u0442\u0438
    \u043A\u043B\u044E\u0447\u043E\u0432\u0435 \u0441\u043B\u043E\u0432\u043E.\n\n\u041B\u0438\u0448\u0435
    \u0432 XIX \u0441\u0442\u043E\u043B\u0456\u0442\u0442\u0456 \u0431\u0443\u043B\u0438
    \u0440\u043E\u0437\u0440\u043E\u0431\u043B\u0435\u043D\u0456 \u0435\u0444\u0435\u043A\u0442\u0438\u0432\u043D\u0456
    \u043C\u0435\u0442\u043E\u0434\u0438 \u043A\u0440\u0438\u043F\u0442\u043E\u0430\u043D\u0430\u043B\u0456\u0437\u0443,
    \u044F\u043A\u0456 \u0434\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u0438 \u0437\u043B\u0430\u043C\u0443\u0432\u0430\u0442\u0438
    \u0446\u0435\u0439 \u0448\u0438\u0444\u0440 \u0431\u0435\u0437 \u0437\u043D\u0430\u043D\u043D\u044F
    \u043A\u043B\u044E\u0447\u0430. \u041D\u0435\u0437\u0432\u0430\u0436\u0430\u044E\u0447\u0438
    \u043D\u0430 \u0446\u0435, \u0448\u0438\u0444\u0440 \u0412\u0456\u0436\u0435\u043D\u0435\u0440\u0430
    \u0437\u0430\u043B\u0438\u0448\u0430\u0454\u0442\u044C\u0441\u044F \u0432\u0430\u0436\u043B\u0438\u0432\u0438\u043C
    \u0435\u0442\u0430\u043F\u043E\u043C \u0440\u043E\u0437\u0432\u0438\u0442\u043A\u0443
    \u043A\u0440\u0438\u043F\u0442\u043E\u0433\u0440\u0430\u0444\u0456\u0457 \u0442\u0430
    \u0447\u0443\u0434\u043E\u0432\u0438\u043C \u043F\u0440\u0438\u043A\u043B\u0430\u0434\u043E\u043C
    \u043F\u043E\u043B\u0456\u0430\u043B\u0444\u0430\u0432\u0456\u0442\u043D\u043E\u0433\u043E
    \u0448\u0438\u0444\u0440\u0443\u0432\u0430\u043D\u043D\u044F.\n\n\n\n\n \u0421\u043F\u0440\u043E\u0431\u0443\u0439\u0442\u0435
    \u043D\u0430\u0442\u0438\u0441\u043D\u0443\u0432\u0448\u0438\n  \u043D\u0430
    \u0456\u043A\u043E\u043D\u043A\u0443"
