    m_PersistentCalls:
      m_Calls: []
  m_text: "\u041E\u0441\u043D\u043E\u0432\u043D\u0456 \u0435\u043B\u0435\u043C\u0435\u043D\u0442\u0438
    \u043A\u0440\u0438\u043F\u0442\u043E\u0433\u0440\u0430\u0444\u0456\u0447\u043D\u043E\u0457
    \u0441\u0438\u0441\u0442\u0435\u043C\u0438\n\n\u0411\u0443\u0434\u044C-\u044F\u043A\u0430
    \u043A\u0440\u0438\u043F\u0442\u043E\u0433\u0440\u0430\u0444\u0456\u0447\u043D\u0430
    \u0441\u0438\u0441\u0442\u0435\u043C\u0430 \u0441\u043A\u043B\u0430\u0434\u0430\u0454\u0442\u044C\u0441\u044F
    \u0437 \u043A\u0456\u043B\u044C\u043A\u043E\u0445 \u0432\u0437\u0430\u0454\u043C\u043E\u043F\u043E\u0432'\u044F\u0437\u0430\u043D\u0438\u0445
    \u0435\u043B\u0435\u043C\u0435\u043D\u0442\u0456\u0432.\n\n \u041F\u0435\u0440\u0448\u0438\u043C
    \u0435\u043B\u0435\u043C\u0435\u043D\u0442\u043E\u043C \u0454 \u043F\u043E\u0432\u0456\u0434\u043E\u043C\u043B\u0435\u043D\u043D\u044F,
    \u044F\u043A\u0435 \u043D\u0435\u043E\u0431\u0445\u0456\u0434\u043D\u043E \u0437\u0430\u0445\u0438\u0441\u0442\u0438\u0442\u0438.\n\n
    \u0414\u0440\u0443\u0433\u0438\u043C \u2014 \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C
    \u0448\u0438\u0444\u0440\u0443\u0432\u0430\u043D\u043D\u044F, \u0442\u043E\u0431\u0442\u043E
    \u043D\u0430\u0431\u0456\u0440 \u043F\u0440\u0430\u0432\u0438\u043B, \u0437\u0430
    \u044F\u043A\u0438\u043C\u0438 \u0432\u0456\u0434\u0431\u0443\u0432\u0430\u0454\u0442\u044C\u0441\u044F
    \u043F\u0435\u0440\u0435\u0442\u0432\u043E\u0440\u0435\u043D\u043D\u044F \u0442\u0435\u043A\u0441\u0442\u0443.\n\n
    \u0422\u0440\u0435\u0442\u0456\u043C \u0432\u0430\u0436\u043B\u0438\u0432\u0438\u043C
    \u0435\u043B\u0435\u043C\u0435\u043D\u0442\u043E\u043C \u0454 \u043A\u043B\u044E\u0447,
    \u0449\u043E \u0432\u0438\u0437\u043D\u0430\u0447\u0430\u0454 \u043A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u0438\u0439
    \u0441\u043F\u043E\u0441\u0456\u0431 \u0432\u0438\u043A\u043E\u043D\u0430\u043D\u043D\u044F
    \u0448\u0438\u0444\u0440\u0443\u0432\u0430\u043D\u043D\u044F.\n\n\u041F\u0456\u0441\u043B\u044F
    \u0437\u0430\u0441\u0442\u043E\u0441\u0443\u0432\u0430\u043D\u043D\u044F \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u0443
    \u0442\u0430 \u043A\u043B\u044E\u0447\u0430 \u0444\u043E\u0440\u043C\u0443\u0454\u0442\u044C\u0441\u044F
    \u0448\u0438\u0444\u0440\u043E\u0442\u0435\u043A\u0441\u0442, \u044F\u043A\u0438\u0439
    \u043C\u043E\u0436\u0435 \u043F\u0435\u0440\u0435\u0434\u0430\u0432\u0430\u0442\u0438\u0441\u044F
    \u043A\u0430\u043D\u0430\u043B\u0430\u043C\u0438 \u0437\u0432'\u044F\u0437\u043A\u0443.
    \n\n\u041E\u0434\u0435\u0440\u0436\u0443\u0432\u0430\u0447 \u0432\u0438\u043A\u043E\u0440\u0438\u0441\u0442\u043E\u0432\u0443\u0454
    \u0432\u0456\u0434\u043F\u043E\u0432\u0456\u0434\u043D\u0438\u0439 \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C
    \u0456 \u043A\u043B\u044E\u0447 \u0434\u043B\u044F \u0432\u0456\u0434\u043D\u043E\u0432\u043B\u0435\u043D\u043D\u044F
    \u043F\u043E\u0447\u0430\u0442\u043A\u043E\u0432\u043E\u0433\u043E \u043F\u043E\u0432\u0456\u0434\u043E\u043C\u043B\u0435\u043D\u043D\u044F.
    \u041D\u0430\u0434\u0456\u0439\u043D\u0456\u0441\u0442\u044C \u0443\u0441\u0456\u0454\u0457
    \u0441\u0438\u0441\u0442\u0435\u043C\u0438 \u0437\u0430\u043B\u0435\u0436\u0438\u0442\u044C
    \u043D\u0435 \u043B\u0438\u0448\u0435 \u0432\u0456\u0434 \u0441\u043A\u043B\u0430\u0434\u043D\u043E\u0441\u0442\u0456
    \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u0443, \u0430 \u0439 \u0432\u0456\u0434
    \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u043E\u0433\u043E \u0432\u0438\u043A\u043E\u0440\u0438\u0441\u0442\u0430\u043D\u043D\u044F
    \u043A\u043B\u044E\u0447\u0456\u0432. \n\n"
