--- !u!114 &1551230746
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1551230744}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u041A\u0440\u0438\u043F\u0442\u043E\u0433\u0440\u0430\u0444\u0456\u044F
    \u2014 \u0446\u0435 \u043D\u0430\u0443\u043A\u0430 \u043F\u0440\u043E \u0437\u0430\u0445\u0438\u0441\u0442
    \u0456\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0456\u0457 \u0448\u043B\u044F\u0445\u043E\u043C
    \u0457\u0457 \u043F\u0435\u0440\u0435\u0442\u0432\u043E\u0440\u0435\u043D\u043D\u044F
    \u0443 \u0444\u043E\u0440\u043C\u0443, \u043D\u0435\u0434\u043E\u0441\u0442\u0443\u043F\u043D\u0443
    \u0434\u043B\u044F \u0441\u0442\u043E\u0440\u043E\u043D\u043D\u0456\u0445 \u043E\u0441\u0456\u0431.
    \n\n\u0407\u0457 \u0433\u043E\u043B\u043E\u0432\u043D\u0435 \u0437\u0430\u0432\u0434\u0430\u043D\u043D\u044F
    \u043F\u043E\u043B\u044F\u0433\u0430\u0454 \u0432 \u0442\u043E\u043C\u0443, \u0449\u043E\u0431
    \u043F\u043E\u0432\u0456\u0434\u043E\u043C\u043B\u0435\u043D\u043D\u044F \u043C\u043E\u0433\u043B\u0438
    \u043F\u0440\u043E\u0447\u0438\u0442\u0430\u0442\u0438 \u043B\u0438\u0448\u0435
    \u0442\u0456, \u043A\u043E\u043C\u0443 \u0432\u043E\u043D\u0438 \u043F\u0440\u0438\u0437\u043D\u0430\u0447\u0435\u043D\u0456.\n\n
    \u041F\u0440\u043E\u0442\u044F\u0433\u043E\u043C \u0442\u0438\u0441\u044F\u0447\u043E\u043B\u0456\u0442\u044C
    \u043B\u044E\u0434\u0438 \u0432\u0438\u043A\u043E\u0440\u0438\u0441\u0442\u043E\u0432\u0443\u0432\u0430\u043B\u0438
    \u0440\u0456\u0437\u043D\u0456 \u0441\u043F\u043E\u0441\u043E\u0431\u0438 \u043F\u0440\u0438\u0445\u043E\u0432\u0443\u0432\u0430\u043D\u043D\u044F
    \u0456\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0456\u0457: \u0432\u0456\u0434
    \u043F\u0440\u043E\u0441\u0442\u0438\u0445 \u0437\u0430\u043C\u0456\u043D \u043B\u0456\u0442\u0435\u0440
    \u0434\u043E \u0441\u043A\u043B\u0430\u0434\u043D\u0438\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u043D\u0438\u0445
    \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u0456\u0432, \u044F\u043A\u0456
    \u043B\u0435\u0436\u0430\u0442\u044C \u0432 \u043E\u0441\u043D\u043E\u0432\u0456
    \u0441\u0443\u0447\u0430\u0441\u043D\u0438\u0445 \u043A\u043E\u043C\u043F'\u044E\u0442\u0435\u0440\u043D\u0438\u0445
    \u0441\u0438\u0441\u0442\u0435\u043C \u0431\u0435\u0437\u043F\u0435\u043A\u0438.\n\n\u0421\u044C\u043E\u0433\u043E\u0434\u043D\u0456
    \u043A\u0440\u0438\u043F\u0442\u043E\u0433\u0440\u0430\u0444\u0456\u044F \u0432\u0438\u043A\u043E\u0440\u0438\u0441\u0442\u043E\u0432\u0443\u0454\u0442\u044C\u0441\u044F
    \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u043D\u043E \u0432\u0441\u044E\u0434\u0438.
    \u0412\u043E\u043D\u0430 \u0437\u0430\u0445\u0438\u0449\u0430\u0454 \u0431\u0430\u043D\u043A\u0456\u0432\u0441\u044C\u043A\u0456
    \u043E\u043F\u0435\u0440\u0430\u0446\u0456\u0457, \u0435\u043B\u0435\u043A\u0442\u0440\u043E\u043D\u043D\u0443
    \u043F\u043E\u0448\u0442\u0443, \u043C\u0435\u0441\u0435\u043D\u0434\u0436\u0435\u0440\u0438,
    \u043F\u0430\u0440\u043E\u043B\u0456, \u0456\u043D\u0442\u0435\u0440\u043D\u0435\u0442-\u0437'\u0454\u0434\u043D\u0430\u043D\u043D\u044F
    \u0442\u0430 \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u043B\u044C\u043D\u0456
    \u0434\u0430\u043D\u0456 \u043A\u043E\u0440\u0438\u0441\u0442\u0443\u0432\u0430\u0447\u0456\u0432.
    \n\n\u0411\u0435\u0437 \u043A\u0440\u0438\u043F\u0442\u043E\u0433\u0440\u0430\u0444\u0456\u0447\u043D\u0438\u0445
    \u043C\u0435\u0442\u043E\u0434\u0456\u0432 \u0431\u0443\u043B\u043E \u0431 \u043D\u0435\u043C\u043E\u0436\u043B\u0438\u0432\u043E
    \u0437\u0430\u0431\u0435\u0437\u043F\u0435\u0447\u0438\u0442\u0438 \u0431\u0435\u0437\u043F\u0435\u0447\u043D\u0438\u0439
    \u043E\u0431\u043C\u0456\u043D \u0456\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0456\u0454\u044E
    \u0432 \u0446\u0438\u0444\u0440\u043E\u0432\u043E\u043C\u0443 \u0441\u0435\u0440\u0435\u0434\u043E\u0432\u0438\u0449\u0456."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
