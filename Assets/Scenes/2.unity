    m_PersistentCalls:
      m_Calls: []
  m_text: "\u0423 \u0446\u0456\u0439 \u043A\u043D\u0438\u0437\u0456 \u0440\u043E\u0437\u0433\u043B\u044F\u0434\u0430\u044E\u0442\u044C\u0441\u044F
    \u043A\u043B\u0430\u0441\u0438\u0447\u043D\u0456 \u043C\u0435\u0442\u043E\u0434\u0438
    \u043A\u0440\u0438\u043F\u0442\u043E\u0433\u0440\u0430\u0444\u0456\u0457, \u044F\u043A\u0456
    \u0441\u0442\u0430\u043B\u0438 \u043E\u0441\u043D\u043E\u0432\u043E\u044E \u0434\u043B\u044F
    \u0440\u043E\u0437\u0432\u0438\u0442\u043A\u0443 \u0441\u0443\u0447\u0430\u0441\u043D\u0438\u0445
    \u0441\u0438\u0441\u0442\u0435\u043C \u0437\u0430\u0445\u0438\u0441\u0442\u0443
    \u0456\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0456\u0457. \u041D\u0435\u0437\u0432\u0430\u0436\u0430\u044E\u0447\u0438
    \u043D\u0430 \u043F\u0440\u043E\u0441\u0442\u043E\u0442\u0443, \u0432\u043E\u043D\u0438
    \u0434\u043E\u043F\u043E\u043C\u0430\u0433\u0430\u044E\u0442\u044C \u0437\u0440\u043E\u0437\u0443\u043C\u0456\u0442\u0438
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0438 \u0448\u0438\u0444\u0440\u0443\u0432\u0430\u043D\u043D\u044F,
    \u0434\u0435\u0448\u0438\u0444\u0440\u0443\u0432\u0430\u043D\u043D\u044F \u0442\u0430
    \u043A\u0440\u0438\u043F\u0442\u043E\u0430\u043D\u0430\u043B\u0456\u0437\u0443,
    \u044F\u043A\u0456 \u0432\u0438\u043A\u043E\u0440\u0438\u0441\u0442\u043E\u0432\u0443\u044E\u0442\u044C\u0441\u044F
    \u0439 \u0441\u044C\u043E\u0433\u043E\u0434\u043D\u0456."
