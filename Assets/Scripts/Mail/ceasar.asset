  mailID: 2
  title: File2
  body: "\u0414\u043E\u0431\u0440\u0438\u0439 \u0434\u0435\u043D\u044C)\n\n\u0411\u0430\u0447\u0443
    \u0442\u0438 \u0432\u0436\u0435 \u0437\u0440\u043E\u0437\u0443\u043C\u0456\u0432
    \u0449\u043E \u043D\u0430 \u0442\u0435\u0431\u0435 \u0447\u0435\u043A\u0430\u0454.
    \u041D\u0443 \u043D\u0435 \u0445\u0432\u0438\u043B\u044E\u0439\u0441\u044F \u0442\u0438
    \u0442\u0430\u043A, \u044F \u0442\u043E\u0431\u0456 \u043D\u0435 \u0432\u043E\u0440\u043E\u0433.\n
    \n\u0412\u0456\u0442\u0430\u044E \u0432 \u0437\u0430\u0445\u043E\u043F\u043B\u044E\u044E\u0447\u043E\u043C\u0443
    \u0441\u0432\u0456\u0442\u0456 \u0448\u0438\u0444\u0440\u0456\u0432, \u0442\u043E\u0431\u0456
    \u0441\u043F\u043E\u0434\u043E\u0431\u0430\u0454\u0442\u044C\u0441\u044F, \u043E\u0431\u0456\u0446\u044F\u044E.
    \u0406 \u0442\u0430\u043A. \u0421\u044C\u043E\u0433\u043E\u0434\u043D\u0456\u0448\u043D\u0454
    \u0437\u0430\u0432\u0434\u0430\u043D\u043D\u044F. \u0414\u043E\u0432\u043E\u043B\u0456
    \u043B\u0435\u0433\u043A\u0435.\n\n\u0414\u0445\u0456\u0437\u0440\u043A\u0447\u0444\u0449\u0434\u0446\u043D
    \u0447\u0442\u0491\u0441\u0434 \u0436\u0443\u0439\u0454\u0441, \u0434\u043F\u0457
    \u0491 \u0443\u0445\u0443\u0446\u0445\u0457 \u0446\u043A\u0434\u043D\u0434\u0447:
    \u0491\u043F\u044F\u0443 \u0447\u043D \u0454\u0457 \u0481\u043D\u0447\u0434\u0457\u0454\u0445,
    \u0454\u0443 \u0445\u0443\u043C\u0444\u0491\u0447\u0456\u0440\u043A\u043D\u043D
    \u043E\u0434 \u0436\u0445\u0454\u0434\u0432\u0454\u0457 \u0436\u0456\u0446\u0454\u0443\u043F
    \u043F\u044F\u0433\u0446\u0454\u0436\u0434.\r\n\r\n\u0424\u0434\u0443\u0454\u0443\u0441
    \u0454\u0457 \u0442\u0434\u043F, \u0434\u043F\u0457 \u0443\u0457\u0443\u0456\u0436\u0456\u0443\u0491\u0454\u043D
    \u0491, \u043E\u0436\u0456\u0446\u0442\u0441, \u0442\u0457 \u0436\u0447\u0446\u0447.\r\n\r\n\u041C\u0443\u0445\u0434
    \u043C\u0436\u0440\u0481\u043D\u0454\u0445 \u0443\u0457\u0444\u0457\u0441\u0443\u043D\u043F\u043D\u0436\u0443,
    \u0443\u0444\u0434\u0435\u0436\u0434?\r\n\r\n\u041D \u0436\u043E\u0434\u0435\u0434\u043F\u043D,
    \u0443\u0443\u0442\u043D \u0446\u043D\u0446\u0456\u0436 \u043D \u0446\u0447\u0437\u0434\u0454,
    \u0491\u0442\u043D\u043D \u0442\u043F\u044F\u0433 \u043C\u0434\u043F\u043D\u0448\u043D\u0454\u043D,
    \u043E\u0444\u0443\u0434\u0447\u0444\u0446\u043D\u0456, \u0449\u0443 \u043E\u0434\u0433\u0434\u0446\u0442\u043D
    \u0436\u043D\u0491\u0446\u0436\u0447\u0434\u0454\u043D \u043E\u0446\u0434\u0481\u0442\u0443
    \u0446\u0442\u0434\u0446\u0442\u0456\u0448\u0457, \u0442\u0456\u0436 \u0444\u0443\u043E\u043C'\u0491\u043E\u0445\u0447\u0434\u0454\u043D.\r\n\r\n\u0416\u0444\u0457\u0448\u0454\u043D-\u0444\u0457\u0448\u0454
    \u0491 \u0436\u043D\u0432\u0444\u0434\u0436 \u0442\u0434\u043D\u043F\u0457\u0446\u0434\u0481\u0456\u0448\u043D\u043D
    \u0436\u0434\u0444\u0456\u0434\u0442\u0454. \u0490\u043F\u044F\u0443 \u0446\u0444\u043D\u0446\u043D\u0436\u043D\u0448\u0446\u0491
    \u0446\u0443 \u0446\u0443\u0481\u0434\u0454\u0442\u0447 \u0442\u0443\u0436\u0442\u0443\u0481\u0434\u0454\u0442\u0443\u0442\u0443
    \u0444\u0457\u0481\u0457\u0442\u0442\u0491, \u0454\u0443 \u043E\u0444\u0443\u0434\u0447\u0444\u0446\u0456\u0454\u0448,
    \u0481\u0443\u043E\u0447.\n\n\u0423\u0434\u0430\u0447\u0456. <3\n\n \u0414\u0430\u043C
    \u0442\u043E\u0431\u0456 \u0446\u0456\u043B\u0438 5 \u0433\u043E\u0434\u0438\u043D
    \u044F\u043A\u0438\u0439 \u044F \u0434\u043E\u0431\u0440\u0438\u0439.\n\nP.s
    \u0421\u0442\u0430\u043D\u0435 \u0441\u043A\u043B\u0430\u0434\u043D\u043E \u043F\u043E\u0433\u043B\u0430\u0434\u044C
    \u043A\u043E\u0442\u0430)"
  backgroundImage: {fileID: 6871649631478177257, guid: fd08cd000ca60a14d9537e3e6e37d80b, type: 3}
  textColor: {r: 0.3295215, g: 1, b: 0.20188677, a: 1}
