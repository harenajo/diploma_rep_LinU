  attachmentIcon: {fileID: 2811729968484509682, guid: d86dc1c32b5fec547ad64b5f5507a97b, type: 3}
  attachmentLockedText: "\u0424\u0430\u0439\u043B \u0437\u0430\u0445\u0438\u0449\u0435\u043D\u043E
    \u043F\u0430\u0440\u043E\u043B\u0435\u043C."
  attachmentUnlockedText: 
  attachmentPassword: "\u0430\u0440\u0445\u0456\u0432"
  maxPasswordAttempts: 3
  saveAttachmentToAiiaArchive: 1
  aiiaHints:
  - text: "\u0414\u0443\u043C\u0430\u044E \u0446\u0435 \u0449\u043E\u0441\u044C \u0431\u0430\u0437\u043E\u0432\u0438\u0445
      \u0448\u0438\u0444\u0440\u0456\u0432. \u0423 \u043B\u0438\u0441\u0442\u0456
      \u0437\u0430\u0431\u0430\u0433\u0430\u0442\u043E \u0434\u0438\u0432\u043D\u0438\u0445
      \u043B\u0456\u0442\u0435\u0440, \u0449\u043E\u0431 \u0446\u0435 \u0431\u0443\u043B\u043E
      \u0432\u0438\u043F\u0430\u0434\u043A\u043E\u0432\u043E.\n"
    emotionName: smile
  - text: "\u041C\u043E\u0436\u043B\u0438\u0432\u043E \u0446\u0435 \u0448\u0438\u0444\u0440
      \u0446\u0435\u0437\u0430\u0440\u044F?"
    emotionName: neutral
  - text: "\u0426\u0435 \u0448\u0438\u0444\u0440 \u0426\u0435\u0437\u0430\u0440\u044F.
      \u0417\u0441\u0443\u0432 5"
    emotionName: other2
  - text: "\u0421\u043F\u0440\u043E\u0431\u0438 \u0437\u0430\u043A\u0456\u043D\u0447\u0438\u043B\u0438\u0441\u044F.
      \u042F \u043D\u0435 \u0431\u0443\u0434\u0443 \u0441\u043C\u0456\u044F\u0442\u0438\u0441\u044F.
      \u041C\u0430\u0439\u0436\u0435. \u0417\u0441\u0443\u0432 5 \u043B\u0456\u0442\u0435\u0440
      \u0432 \u043F\u0440\u0430\u0432\u043E.\n"
    emotionName: other2
  aiiaNoMoreHintsText: "\u0411\u0456\u043B\u044C\u0448\u0435 \u043F\u0456\u0434\u043A\u0430\u0437\u043E\u043A
    \u043D\u0435\u043C\u0430\u0454. \u042F \u0456 \u0442\u0430\u043A \u0442\u043E\u0431\u0456
    \u0432\u0436\u0435 \u043F\u0456\u0434\u043A\u0430\u0437\u0430\u043B\u0430"
  aiiaNoMoreHintsEmotion: Angry
  aiiaFailedAttemptsHint: "\u0421\u043F\u0440\u043E\u0431\u0438 \u0437\u0430\u043A\u0456\u043D\u0447\u0438\u043B\u0438\u0441\u044F.
    \u041C\u043E\u0436\u043D\u0430 \u043F\u043E\u0432\u0435\u0440\u043D\u0443\u0442\u0438\u0441\u044F
    \u0434\u043E \u043B\u0438\u0441\u0442\u0430 \u0439 \u043F\u0435\u0440\u0435\u0447\u0438\u0442\u0430\u0442\u0438
    \u0439\u043E\u0433\u043E \u0443\u0432\u0430\u0436\u043D\u0456\u0448\u0435."
